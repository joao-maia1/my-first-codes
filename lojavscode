<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lojinha</title>
    <link rel="stylesheet" href="css/bootstrap.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="css/style.css">
    <script src="js/fun.js"></script>
</head>
<body>
<div class="container">
    <h1> <i id="crifao" class="bi bi-cart-check"></i> Lojinha do Jonão</h1>
  <table class="table table-hover table-striped table-dark"> 
    <thead> 
        <tr>
            <th>Imagem</th>
            <th>Produto</th>
            <th>Preço Unitário</th>
            <th>Quantidade</th>
            <th>Preço Total</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>
                <img src="img/produto1.webp" alt="Produto 1" width="170">
            </td>
            <td>
                <div>Celular: Iphone 16 Pro Max 1TB</div>
                <div>Código: 123456789</div>
                <div>Cor: Branco</div> 
            </td>
            <td id="preco1">R$ 10.000,00</td>
            <td>
                <span class="badge text-bg-danger" onclick="alterarQuantidade(1, '-')"><i class="bi bi-chevron-down"></i></i></span>
                <span id="quantidade1">0</span>
                <span class="badge text-bg-success" onclick="alterarQuantidade(1, '+')"><i class="bi bi-chevron-compact-up"></i></span>
            </td>
            <td id="total1">R$ 0,00</td>
        </tr>
        <tr>
            <td>
                <img src="img/produto2.webp" alt="Produto 2" width="200">
            </td>
            <td>
                <div>Notebook: Alienware Megablaster</div>
                <div>Código: 987654321</div>
                <div>Cor: Preto</div> 
            </td>
            <td id="preco2">R$ 8.000,00</td>
            <td>
                <span class="badge text-bg-danger" onclick="alterarQuantidade(2, '-')"><i class="bi bi-chevron-down"></i></i></span>
                <span id="quantidade2">0</span>
                <span class="badge text-bg-success" onclick="alterarQuantidade(2, '+')"><i class="bi bi-chevron-compact-up"></i></span></td>
            <td id="total2">R$ 0,00</td>
        </tr>
        <tr>
            <td>
                <img src="img/produto3.jpg" alt="Produto 3" width="200">
            </td>
            <td>
                <div>TV 4K QLED</div>
                <div>Código: 555555555</div>
                <div>Cor: Preta</div> 
            </td>
            <td id="preco3">R$ 15.000,00</td>
            <td>
                <span class="badge text-bg-danger" onclick="alterarQuantidade(3, '-')"><i class="bi bi-chevron-down"></i></i></span>
                <span id="quantidade3">0</span>
                <span class="badge text-bg-success" onclick="alterarQuantidade(3, '+')"><i class="bi bi-chevron-compact-up"></i></span>
            </td>
            <td id="total3">R$ 0,00</td>
        </tr>
    </tbody>
  </table>
  <footer>
    <span>
        Subtotal: R$ 0,00 <span id="subtotal"></span>
    </span>
  </footer>
  </div>
</body>
</html>
